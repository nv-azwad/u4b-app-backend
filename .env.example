# Server
PORT=5000

# Database (PostgreSQL)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=u4b_database
DB_PASSWORD=your_password
DB_PORT=5432

# Authentication
JWT_SECRET=your-jwt-secret-key-at-least-32-characters

# Email (Gmail SMTP - use App Password, not regular password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Google Cloud Storage
GCS_BUCKET_NAME=your-gcs-bucket-name

# Wix Integration (for voucher promo codes)
WIX_U4B_API_URL=https://your-wix-api-endpoint
WIX_BB_API_URL=https://your-wix-bb-api-endpoint
